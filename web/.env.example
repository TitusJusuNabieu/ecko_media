# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ecko_media?schema=public"

# Authentication
JWT_SECRET=change-this-to-a-secure-random-string-minimum-32-characters-long

# Application
NODE_ENV=development

# API URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# AzuraCast Streaming URL (Update after setting up AzuraCast)
NEXT_PUBLIC_STREAM_URL=http://your-azuracast-ip:8000/radio.mp3

# Contact Information
NEXT_PUBLIC_PHONE_1=+23278051555
NEXT_PUBLIC_PHONE_2=+23299051555
NEXT_PUBLIC_WEBSITE=www.eckomedia.sl
NEXT_PUBLIC_EMAIL=info@eckomedia.sl

