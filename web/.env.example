# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ecko_media

# Authentication
JWT_SECRET=change-this-to-a-secure-random-string-minimum-32-characters-long

# Application
NODE_ENV=development

# API URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# AzuraCast Streaming Server
# Update with your AzuraCast stream URL from DigitalOcean droplet
NEXT_PUBLIC_STREAM_URL=http://your-azuracast-ip:8000/radio.mp3

# Contact Information
NEXT_PUBLIC_PHONE_1=+23278051555
NEXT_PUBLIC_PHONE_2=+23299051555
NEXT_PUBLIC_WEBSITE=www.eckomedia.sl
NEXT_PUBLIC_EMAIL=info@eckomedia.sl

# Optional: External job listings source (if applicable)
# JOB_LISTINGS_SOURCE=your_external_source_here
# For local job listings, the application uses the internal job_listings table in the database.
